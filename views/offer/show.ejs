<%- include('../partials/header.ejs')%>

    <div class="col-md-3"></div>
        <div class="col-md-6">
            <div class="card mx-auto">
                <div class="card-body">
                    <h2 class="card-title">Offers received for: <%=item.title%></h2>

                    <%if(!item.active) {%>
                        <table class="table">
                        <tr>
                            <th>Buyer</th>
                            <th>Amount</th>
                            <th>Action</th>
                        </tr>
                        <%offers.forEach(offer=>{%>
                        <tr>
                            <td><%= offer.item.title%></td>
                            <td>$<%= offer.amount%></td>
                            <td><%= offer.status%></td>
                        </tr>
                        <% });%>
                        </table>
                    <%} else {%>
                        <table class="table">
                            <tr>
                                <th>Buyer</th>
                                <th>Amount</th>
                                <th>Status</th>
                            </tr>
                            <%offers.forEach(offer=>{%>
                            <tr>
                                <td><%= offer.item.title%></td>
                                <td>$<%= offer.amount%></td>
                                <td>
                                    <form>
                                        <button class="btn btn-sm btn-outline-primary" type="submit" formmethod="POST" formaction="/items/<%= offer.item.id%>/offers/<%= offer.id%>" >Accept</button>
                                    </form>
                                </td>
                            </tr>
                            <% });%>
                        </table>        
                    <%}%>
                </div>
            </div>
        </div>
        <div class="col-md-3"></div>
    </div>

<%- include('../partials/footer.ejs')%>
