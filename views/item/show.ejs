<%- include('../partials/header.ejs')%>
    
      <div class="d-none d-flex-lg col-xl-2"></div>
      <div class="col-md-6 col-lg-4 col-xl-3 my-2">

        <div class="card">
          <img class="card-img" src="/images/<%= item.image%>" alt="...">
        </div>


      </div>
      
      <div class="col-md-6 col-lg-8 col-xl-7 my-2">
        <div class="h-75 card">
        <div class="card-body">
          <h4 class="card-title text-truncate"><%= item.title%></h4>
          <ul class="list-group list-group-flush">
            <li class="list-group-item">Posted: <%= item.createdAt%></li>
            <li class="list-group-item">Condition: <%= item.condition%></li>
            <li class="list-group-item">Price: $<%= item.price%> | <%= item.totalOffers%> Offers</li>
            <li class="list-group-item">Seller: <%= item.seller.firstname + ' ' + item.seller.lastname%></li>
          </ul> 
          <p class="card-text"><%= item.details%></p>

          <%if(item.active) {%>
            <form class="d-flex justify-content-end" action="/items/<%= item.id%>/offers/" method='POST'>
            
              <div>
                <input name="amount" type="amount" class="form-control" id="amount" min="0.01" step="0.01" required>
              </div>
              <button type="submit" class="btn btn-primary ml-1">Make an Offer</button>
              
            </form>
            <%if(item.totalOffers > 0) {%>
              <p class="card-text text-danger">Current highest offer: <%= item.highestOffer%></p>
            <%}%>
          <%} else {%>
            <p class="card-text text-danger">Unfortunately, this item is no longer available.</p>
          <%}%>
          
        </div>
        </div>
      </div>
  
<%- include('../partials/footer.ejs')%>